rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return signedIn() && request.auth.token.email == 'master@admin.com';
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isIT() {
      return signedIn() && (isMasterAdmin() || (userDoc().exists() && userDoc().data.role == 'it'));
    }

    function isOwnUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwnUser(userId) || isIT() || isMasterAdmin();
      allow create: if signedIn() && (isOwnUser(userId) || isMasterAdmin());
      allow update: if isOwnUser(userId) || isIT() || isMasterAdmin();
      allow delete: if isMasterAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if isIT() || isMasterAdmin() || (signedIn() && resource.data.creatorId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isIT() || isMasterAdmin() || (signedIn() && resource.data.creatorId == request.auth.uid && request.resource.data.creatorId == resource.data.creatorId);
      allow delete: if isMasterAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
